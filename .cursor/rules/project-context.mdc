│   ├── chain_analysis.py    # Skill 2: 代码链路分析
│   └── plan_suggestion.py   # Skill 3: 需求方案建议
├── tools/
│   ├── file_reader.py   # 文件读取
│   ├── code_search.py   # ripgrep 代码搜索
│   ├── tree_parser.py   # Tree-sitter 结构解析
│   └── vector_search.py # FAISS 语义检索
├── prompts/
