# ============================================================
# PaySkillCreator — 多模型配置
# ============================================================
# 支持多个 LLM Provider，只需填入对应 Provider 的 API Key 即可启用。
# 未填写 API Key 的 Provider 的模型不会在前端展示。

# ============================================================
# Provider 1: 阿里百炼 (DashScope) — 推荐
# ============================================================
# 在 https://bailian.console.aliyun.com/ 获取 API Key
# 可用模型: qwen-turbo / qwen-plus / qwen-max / qwen-long
DASHSCOPE_API_KEY=sk-your-dashscope-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 也支持旧版变量名（向后兼容，优先级低于 DASHSCOPE_API_KEY）
# OPENAI_API_KEY=sk-your-dashscope-api-key-here
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ============================================================
# Provider 2: MiniMax（可选）
# ============================================================
# 在 https://platform.minimaxi.com/ 获取 API Key
# 可用模型: abab6.5s-chat / abab6.5-chat
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1

# ============================================================
# Provider 3: OpenAI（可选）
# ============================================================
# 可用模型: gpt-4o / gpt-4o-mini
OPENAI_NATIVE_API_KEY=
OPENAI_NATIVE_BASE_URL=https://api.openai.com/v1

# ============================================================
# 默认模型 — 前端默认选中 & CLI 默认使用
# ============================================================
MODEL_NAME=qwen-plus

# ============================================================
# 目标仓库路径 — 要分析的代码仓库的本地绝对路径
# ============================================================
TARGET_REPO_PATH=/path/to/your/target/repo

# ============================================================
# 可选配置
# ============================================================
LOG_LEVEL=INFO
MAX_CONTEXT_TOKENS=8000
NEED_HUMAN_REVIEW=false
