# ============================================================
# LLM API 配置 — 阿里云百炼 (DashScope) 兼容 OpenAI 接口
# ============================================================

# 你的百炼 API Key（在 https://bailian.console.aliyun.com/ 获取）
# 格式: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-your-dashscope-api-key-here

# 百炼 OpenAI 兼容接口地址（固定值，无需修改）
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 模型名称（百炼支持的模型，推荐以下选项）
#   qwen-plus        — 性价比高，推荐日常使用
#   qwen-turbo       — 更快更便宜，适合简单任务
#   qwen-max         — 最强能力，适合复杂分析
#   qwen-long        — 长上下文支持（100万 tokens）
MODEL_NAME=qwen-plus

# ============================================================
# 目标仓库路径 — 要分析的代码仓库的本地绝对路径
# ============================================================
TARGET_REPO_PATH=/path/to/your/target/repo

# ============================================================
# 可选配置
# ============================================================
LOG_LEVEL=INFO
MAX_CONTEXT_TOKENS=8000
NEED_HUMAN_REVIEW=false
